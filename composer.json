{
  "name": "kae/korea-auto-export",
  "description": "Korea Auto Export — premium Korean car import platform for Algerian buyers. Custom PHP 8.3 MVC.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "filp/whoops": "^2.15"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Helpers/helpers.php"
    ]
  },
  "scripts": {
    "test": "phpunit",
    "serve": "php -S 127.0.0.1:8000 -t public"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
