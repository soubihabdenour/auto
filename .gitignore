.DS_Store
.idea/
.vscode/
*.log

# Env / secrets
.env
.env.*.local

# Dependencies (Phase 1+)
/vendor/
/node_modules/

# Runtime
/storage/cache/*
!/storage/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/sessions/*
!/storage/sessions/.gitkeep

# Uploads (Phase 2+)
/public/uploads/*
!/public/uploads/.gitkeep

# Build artifacts (Phase 4+)
/public/assets/dist/

# Deploy archives (generated by bin/prepare-deploy.sh)
/kae-deploy-*.tar.gz

# Backups
/storage/backups/*
!/storage/backups/.gitkeep
