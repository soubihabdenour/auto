#-----------------------------------------------------------
# Korea Auto Export — Environment configuration
# Copy to .env and adjust per environment. Never commit .env.
#-----------------------------------------------------------

APP_NAME="Korea Auto Export"
APP_ENV=local                  # local | staging | production
APP_DEBUG=true                 # false in production
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Algiers
APP_KEY=                       # 32+ random chars; used for CSRF/session salting

# Default locale and supported locales (comma-separated)
APP_LOCALE=ar
APP_LOCALES=ar,fr,en
APP_FALLBACK_LOCALE=en

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=koreaautoexport
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Session
SESSION_NAME=kae_session
SESSION_LIFETIME=7200          # seconds
SESSION_SECURE=false           # true in production (HTTPS)
SESSION_SAMESITE=Lax

# Storage
STORAGE_DRIVER=local           # local | s3 (s3 reserved for v2)
STORAGE_PUBLIC_URL=/uploads

# Mail (Phase 2)
MAIL_DRIVER=smtp               # smtp | log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_ADDRESS="noreply@koreaautoexport.dz"
MAIL_FROM_NAME="Korea Auto Export"

# Rate limiting
RATE_LIMIT_LEAD_PER_HOUR=5
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15

# Logging
LOG_LEVEL=info                 # debug | info | warning | error
